{
    "name": "phpdevkits/forge-sdk",
    "description": "A modern PHP SDK for the Laravel Forge API, powered by Saloon.",
    "keywords": ["php", "sdk", "laravel", "forge", "laravel-forge", "saloon", "api-client"],
    "license": "MIT",
    "authors": [
        {
            "name": "Francisco Barrento",
            "email": "francisco.barrento@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "saloonphp/saloon": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29.1",
        "pestphp/pest": "^5.0.0",
        "pestphp/pest-plugin-type-coverage": "^5.0.0",
        "phpstan/phpstan": "^2.1.54",
        "rector/rector": "^2.4.2",
        "symfony/var-dumper": "^8.0.8"
    },
    "autoload": {
        "psr-4": {
            "PhpDevKits\\ForgeSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "lint": [
            "pint --parallel",
            "rector"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:refactor": "rector --dry-run",
        "test:unit": "pest --parallel --coverage --exactly=100",
        "test:types": "phpstan",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    }
}
